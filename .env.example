POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# Admin credentials (used by Spring Security and by retrain.sh for the reload curl)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ML model prediction (Phase 2)
# Set ML_ENABLED=true after first successful training run (scripts/retrain.sh)
ML_ENABLED=false
ML_MODEL_DIR=/models
