POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=your_db_name

# Admin credentials (used by Spring Security and by retrain.sh for the reload curl)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me

# ML model prediction (Phase 2)
# Set ML_ENABLED=true after first successful training run (scripts/retrain.sh)
ML_ENABLED=false
ML_MODEL_DIR=/models

# User accounts / transactional email (Mailgun SMTP)
# APP_MAIL_ENABLED=false logs emails to the app log instead of sending (dev mode).
APP_MAIL_ENABLED=true
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=postmaster@your-mailgun-domain
SMTP_PASSWORD=your_mailgun_smtp_password
MAIL_FROM=noreply@your-mailgun-domain
# Canonical https base URL of the site — used to build links in emails.
APP_BASE_URL=https://your-domain.example
# Backfilled onto the admin account at startup (enables admin password reset).
ADMIN_EMAIL=deppfij@gmail.com

# Netdata monitoring
# Password for the low-privilege 'netdata' Postgres role (created by Flyway V21).
# Set BEFORE the first deploy that runs V21; alphanumeric only (it is embedded in a DSN URL).
NETDATA_DB_PASSWORD=change_me_strong_alphanumeric
# ntfy.sh push topic for alerts — pick a private/unguessable topic and subscribe in the ntfy app.
NETDATA_NTFY_TOPIC_URL=https://ntfy.sh/your-private-topic
